f <- leaflet(data = coords7) |>
addTiles() |>
addProviderTiles(providers$Esri.WorldPhysical) |>
# 1. Your original fixed diamonds
addMarkers(
~Lng, ~Lat,
popup = paste("Site:", coords7$Site, "<br>", "Age:", coords7$Proposed.Absolute.Age),
icon = symbols
) |>
# 2. Draggable labels with a truly invisible anchor
addMarkers(
~Lng, ~Lat,
# This creates a zero-size box with no image and no pin
icon = divIcon(className = "invisible-drag-handle", iconSize = c(0, 0)),
options = markerOptions(draggable = TRUE),
label = ~Number,
labelOptions = labelOptions(
noHide = TRUE,
textOnly = TRUE,
direction = 'center',
style = list(
"color" = "black",
"font-family" = "serif",
"font-size" = "11px",
"font-weight" = "bold")
)
)
