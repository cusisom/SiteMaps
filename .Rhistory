# 2. Add the labels as 'invisible' draggable markers
f <- f |>
addMarkers(
data = coords7,
~Lng, ~Lat,
# This URL is a 1x1 transparent pixel
icon = makeIcon(
iconUrl = "https://upload.wikimedia.org",
iconWidth = 24, iconHeight = 24 # The "grab" area
),
options = markerOptions(draggable = TRUE),
label = ~Number,
labelOptions = labelOptions(
noHide = TRUE,
textOnly = TRUE,
direction = 'center', # Places the "invisible handle" directly on the text
style = list(
"color" = "black",
"font-family" = "serif",
"font-size" = "11px",
"font-weight" = "bold")
)
)
f
# 2. Add labels using a null-size DivIcon to avoid the "broken image"
f <- f |>
addMarkers(
data = coords7,
~Lng, ~Lat,
# We create a 'div' with no content and no size so nothing renders visually
icon = divIcon(
className = "empty-icon",
iconSize = c(0, 0)
),
options = markerOptions(draggable = TRUE),
label = ~Number,
labelOptions = labelOptions(
noHide = TRUE,
textOnly = TRUE,
direction = 'center',
style = list(
"color" = "black",
"font-family" = "serif",
"font-size" = "11px",
"font-weight" = "bold")
)
)
# 2. Add labels as invisible but draggable markers
f <- f |>
addMarkers(
data = coords7,
~Lng, ~Lat,
# Hides the marker (pin) completely without needing an external image
options = markerOptions(draggable = TRUE, opacity = 0),
label = ~Number,
labelOptions = labelOptions(
noHide = TRUE,
textOnly = TRUE,
direction = 'center',
style = list(
"color" = "black",
"font-family" = "serif",
"font-size" = "11px",
"font-weight" = "bold")
)
)
