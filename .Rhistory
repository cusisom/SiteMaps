addTiles() %>%
addProviderTiles(providers$Esri.WorldPhysical) %>%
addMarkers(
~Lng, ~Lat,
popup = paste("Site:", coords6$Site, "<br>",
"Age:", coords6$Proposed.Absolute.Age),
icon = symbols
) %>%
# 2. Add the numbers as independent, draggable "label markers"
addLabelOnlyMarkers(
~Lng, ~Lat,
label = ~Number,
# This makes only the text draggable
options = markerOptions(draggable = TRUE),
labelOptions = labelOptions(
noHide = TRUE,
textOnly = TRUE,
direction = 'right',
offset = c(5, 5),
style = list(
"color" = "black",
"font-family" = "serif",
"font-size" = "11px",
"font-weight" = "bold")
)
)
